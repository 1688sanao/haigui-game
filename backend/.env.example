# 复制为 .env 后填写（勿将 .env 提交到仓库）
# 在 Vercel 部署时：在 Project → Settings → Environment Variables 中同步配置以下变量（无需上传 .env）
# DeepSeek OpenAI 兼容接口
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 后端监听
PORT=3001
HOST=localhost

# 可选：逗号分隔的额外 CORS 来源（如局域网调试 http://192.168.x.x:5173）
# CORS_ORIGINS=http://192.168.1.100:5173
